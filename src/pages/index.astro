---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/home.css';
import WalletButton from '../components/wallet/WalletButton';   // registers the Lit custom element
---

<BaseLayout title="Cardano P2P • Trade Anything, Own Everything">

  <div class="home-container">

    <!-- HERO -->
    <section class="hero">
      <div class="hero-content">
        <h1>Peer-to-Peer Commerce.<br><span>On Cardano.</span></h1>
        
        <p>Connect your wallet • Buy & sell services or items directly with other users • Powered by a self-governed community token.</p>

        <!-- Real wallet button as client island -->
        <div class="wallet-button-container">
          <WalletButton client:load />
        </div>

        <p class="wallets">Supported wallets: Nami • Eternl • Flint • Lace • Typhon</p>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="features">
      <div class="home-container">
        <div class="grid">
          <div class="feature-card">
            <div class="icon">🔄</div>
            <h3>True P2P</h3>
            <p>No middlemen. Direct wallet-to-wallet trades secured by Cardano smart contracts.</p>
          </div>
          <div class="feature-card">
            <div class="icon">🪙</div>
            <h3>$DAP Token</h3>
            <p>Community governed. Stake, vote on upgrades, and earn from platform activity.</p>
          </div>
          <div class="feature-card">
            <div class="icon">🔐</div>
            <h3>Wallet-First</h3>
            <p>Your wallet is your identity. No accounts, no passwords, full ownership.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="how-it-works">
      <div class="home-container">
        <h2>How it works in 3 steps</h2>
        <div class="steps-grid">
          <div class="step">
            <div class="number">1️⃣</div>
            <h4>Connect Wallet</h4>
            <p>Instant sign-in with any CIP-30 compatible Cardano wallet.</p>
          </div>
          <div class="step">
            <div class="number">2️⃣</div>
            <h4>List or Browse</h4>
            <p>Post your services, digital goods or physical items on-chain.</p>
          </div>
          <div class="step">
            <div class="number">3️⃣</div>
            <h4>Trade & Govern</h4>
            <p>Secure escrow via smart contracts. Vote on platform decisions with $DAP.</p>
          </div>
        </div>
      </div>
    </section>

  </div>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="home-container">
      <p>Built on Cardano • Self-governed • Zero middlemen</p>
      <p>© 2026 AmdTel Blockchain Dev • feature/home-dashboard-layouts</p>
    </div>
  </footer>

</BaseLayout>