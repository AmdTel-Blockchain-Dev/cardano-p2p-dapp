# ======================
# AUTH SECURITY (Critical - change this before production!)
# ======================
AUTH_SECRET=ChangeThisToASecureRandomStringBeforeProduction

# ======================
# Optional / Future settings (you can leave these for now)
# ======================
# NODE_ENV=development
# PUBLIC_SITE_URL=http://localhost:4321

# Cardano provider (we'll use this later for token & marketplace)
# BLOCKFROST_PROJECT_ID=your_blockfrost_key_here   # keep commented until needed

# Web3Auth (we'll add this in the next phase if you want the social login button)
# WEB3AUTH_CLIENT_ID=your_web3auth_client_id_here